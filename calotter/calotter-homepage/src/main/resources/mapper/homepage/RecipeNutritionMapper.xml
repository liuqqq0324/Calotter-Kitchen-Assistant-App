<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.calotter.homepage.mapper.RecipeNutritionMapper">

    <select id="selectByRecipeId" resultType="com.calotter.homepage.domain.vo.RecipeNutritionVo">
        SELECT *
        FROM sous_chef_hp.hp_recipe_nutrition
        WHERE recipe_id = #{recipeId}
        LIMIT 1
    </select>

</mapper>
