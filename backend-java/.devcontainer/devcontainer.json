{
  "name": "SousChef Backend (Java + Postgres)",
  
  // 核心魔法：这里引用了两个 compose 文件
  // 1. "../docker-compose.yml" -> 你的数据库
  // 2. "docker-compose.yml"    -> 刚才定义的 Java 环境
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.yml"
  ],

  // 告诉 VS Code，我们的主战场是 "app" 这个服务（Java容器）
  "service": "app",
  
  // 项目在容器里的路径
  "workspaceFolder": "/workspaces/backend-java",

  // 自动帮队友安装好插件（再也不用喊队友装插件了！）
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",      // Java 核心包
        "vmware.vscode-spring-boot",     // Spring Boot 工具
        "Pivotal.vscode-boot-dev-pack",  // Spring 开发包
        "humao.rest-client"              // API 测试工具
      ]
    }
  },

  // 使用非 root 用户运行（更安全，也就是镜像里自带的 vscode 用户）
  "remoteUser": "vscode"
}