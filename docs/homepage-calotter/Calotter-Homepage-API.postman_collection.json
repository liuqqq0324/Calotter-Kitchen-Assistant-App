{
	"info": {
		"_postman_id": "calotter-homepage-api-collection",
		"name": "Calotter Homepage API - 营养追踪和摄入管理",
		"description": "Calotter Homepage模块相关的营养目标、营养摘要和摄入记录管理API集合\n\n注意：默认端口为10001，可在application.yml中修改",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "营养相关 API",
			"item": [
				{
					"name": "获取周营养目标",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/nutrition/targets/weekly",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"nutrition",
								"targets",
								"weekly"
							]
						},
						"description": "获取当前用户的周营养目标。如果用户当前周没有营养目标，系统会自动根据用户的身体数据（身高、体重、年龄、性别）计算并创建。\n\n响应格式：\n```json\n{\n  \"code\": 200,\n  \"msg\": \"操作成功\",\n  \"data\": {\n    \"weeklyTarget\": {...},\n    \"basis\": {...}\n  }\n}\n```"
					},
					"response": []
				},
				{
					"name": "获取周营养摘要",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/nutrition/summary?period=week",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"nutrition",
								"summary"
							],
							"query": [
								{
									"key": "period",
									"value": "week",
									"description": "时间周期，目前只支持week"
								}
							]
						},
						"description": "获取当前用户的周营养摘要，包括已消费和剩余的营养成分。\n\n响应格式：\n```json\n{\n  \"code\": 200,\n  \"msg\": \"操作成功\",\n  \"data\": {\n    \"period\": \"week\",\n    \"weekStart\": \"2025-11-24\",\n    \"weekEnd\": \"2025-11-30\",\n    \"consumed\": {...},\n    \"remaining\": {...}\n  }\n}\n```"
					},
					"response": []
				}
			],
			"description": "营养目标和摘要相关的API"
		},
		{
			"name": "摄入记录 API",
			"item": [
				{
					"name": "获取今日摄入 (全部)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/intake/today?source=all",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"intake",
								"today"
							],
							"query": [
								{
									"key": "source",
									"value": "all",
									"description": "来源类型：recipe(菜谱), manual(手动), all(全部)"
								}
							]
						},
						"description": "获取今日的所有摄入记录（包括菜谱来源和手动输入）"
					},
					"response": []
				},
				{
					"name": "获取今日摄入 (菜谱来源)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/intake/today?source=recipe",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"intake",
								"today"
							],
							"query": [
								{
									"key": "source",
									"value": "recipe",
									"description": "只返回菜谱来源的摄入记录"
								}
							]
						},
						"description": "获取今日的菜谱来源摄入记录"
					},
					"response": []
				},
				{
					"name": "获取今日摄入 (手动来源)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/intake/today?source=manual",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"intake",
								"today"
							],
							"query": [
								{
									"key": "source",
									"value": "manual",
									"description": "只返回手动输入的摄入记录"
								}
							]
						},
						"description": "获取今日的手动输入摄入记录"
					},
					"response": []
				},
				{
					"name": "更新摄入百分比",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"consumedPercentage\": 80\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/intake/{{intake_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"intake",
								"{{intake_id}}"
							]
						},
						"description": "更新指定摄入记录的消费百分比（0-100）。系统会自动重新计算有效营养成分，并返回更新后的周营养摘要。\n\n注意：需要先获取一个intake_id，可以从\"获取今日摄入\"接口的响应中获取。\n\n请求体：\n```json\n{\n  \"consumedPercentage\": 80\n}\n```"
					},
					"response": []
				},
				{
					"name": "添加手动摄入",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"date\": \"2025-11-29\",\n  \"foodName\": \"fried rice with egg\",\n  \"portionDescription\": \"1 bowl\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/intake/manual",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"intake",
								"manual"
							]
						},
						"description": "添加手动输入的摄入记录。系统会根据食物名称估算营养成分（当前为简化版本）。\n\n请求参数说明：\n- date: 可选，默认为今天，格式：YYYY-MM-DD\n- foodName: 必需，食物名称\n- portionDescription: 可选，份量描述\n\n请求体示例：\n```json\n{\n  \"date\": \"2025-11-29\",\n  \"foodName\": \"fried rice with egg\",\n  \"portionDescription\": \"1 bowl\"\n}\n```"
					},
					"response": []
				}
			],
			"description": "摄入记录管理相关的API"
		},
		{
			"name": "认证相关 (前置步骤)",
			"item": [
				{
					"name": "用户登录",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.accessToken || jsonData.data?.accessToken) {",
									"        var token = jsonData.accessToken || jsonData.data.accessToken;",
									"        pm.collectionVariables.set(\"access_token\", token);",
									"        console.log(\"Token已保存到collection变量: \" + token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"testuser\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/ums/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"ums",
								"auth",
								"login"
							]
					},
					"description": "用户登录获取access token。登录成功后，token会自动保存到collection变量中。\n\n注意：请根据实际情况修改用户名和密码。\n\n如果登录接口路径不同，请修改URL。"
				}
			],
			"description": "在使用其他API之前，需要先登录获取access token"
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:10001",
			"type": "string",
			"description": "Calotter Homepage服务的基础URL，默认端口10001"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string",
			"description": "JWT访问令牌，登录后自动填充"
		},
		{
			"key": "intake_id",
			"value": "",
			"type": "string",
			"description": "摄入记录ID，用于更新摄入百分比接口"
		}
	]
}
