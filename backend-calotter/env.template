# ========================================
# 环境变量模板（Environment Variables Template）
# ========================================
# 
# 使用说明：
# 1. 复制本文件为 .env
#    cp env.template .env
# 
# 2. 填入你的真实 API Keys（不要提交到 Git）
# 
# 3. 加载环境变量到当前终端：
#    source .env
#    或者：
#    export $(cat .env | xargs)
# 
# 4. 然后启动后端：
#    cd calotter-start
#    mvn spring-boot:run
# 
# ========================================

# ========================================
# AI API Keys
# ========================================

# Gemini API Key（如果使用 ai.api.mode=gemini）
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key（主要使用，如果使用 ai.api.mode=groq）
GROQ_API_KEY=your_groq_api_key_here

# AWS Bedrock Bearer Token（已弃用，保留以备后用）
# ⚠️ 这是短期 token，过期后需要在 AWS 控制台重新获取
# 格式：bedrock-api-key-xxxxx（完整的 Bearer token）
# BEDROCK_API_KEY=your_bedrock_bearer_token_here

# ========================================
# 其他环境变量（如有需要可在此添加）
# ========================================

