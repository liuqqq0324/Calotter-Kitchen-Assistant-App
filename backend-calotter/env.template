# ========================================
# 环境变量模板（Environment Variables Template）
# ========================================
# 
# 使用说明：
# 1. 复制本文件为 .env（在 backend-calotter 目录下）
#    cp env.template .env
# 
# 2. 填入你的真实 API Keys（不要提交到 Git）
# 
# 3. 直接启动后端，Spring Boot 会自动加载 .env 文件：
#    cd calotter-start
#    mvn spring-boot:run
# 
# 注意：
# - .env 文件应放在 backend-calotter 目录下（项目根目录）
# - Spring Boot 启动时会自动加载 .env 文件中的环境变量
# - 无需手动 source 或 export 环境变量
# 
# ========================================

# ========================================
# AI API Keys
# ========================================

# Gemini API Key（如果使用 ai.api.mode=gemini）
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key（主要使用，如果使用 ai.api.mode=groq）
GROQ_API_KEY=your_groq_api_key_here

# AWS Bedrock Bearer Token（已弃用，保留以备后用）
# ⚠️ 这是短期 token，过期后需要在 AWS 控制台重新获取
# 格式：bedrock-api-key-xxxxx（完整的 Bearer token）
# BEDROCK_API_KEY=your_bedrock_bearer_token_here

# ========================================
# 其他环境变量（如有需要可在此添加）
# ========================================

